{
  "name": "panda-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:web": "node scripts/build-web.mjs",
    "check": "npm run check:protocol && npm run check:sdk && npm run check:worker && npm run check:captoken && npm run check:connector && npm run check:relay-boundary && npm run check:relay-backpressure && npm run check:e2ee && npm run check:desktop",
    "check:protocol": "node packages/protocol/test/protocol.test.mjs",
    "check:sdk": "node --test packages/sdk/test/",
    "check:worker": "node apps/cloud-worker/test/worker.test.mjs",
    "check:captoken": "node apps/cloud-worker/test/captoken.test.mjs",
    "check:connector": "node apps/connector-cli/test/connector.test.mjs",
    "check:relay-boundary": "node scripts/verify/relay-boundary.mjs",
    "check:relay-backpressure": "node scripts/verify/relay-backpressure.mjs",
    "check:e2ee": "node scripts/verify/relay-e2ee.mjs",
    "check:desktop": "npm --workspace @panda-bridge/desktop run check",
    "verify:local": "node scripts/verify/local-smoke.mjs",
    "verify:sdk-examples": "node examples/sdk-call-examples/run-local.mjs",
    "verify:minimal-caller": "node examples/minimal-caller/run-local.mjs",
    "verify:cloud": "node scripts/verify/cloud-smoke.mjs",
    "verify:browser": "node scripts/verify/browser-smoke.mjs",
    "verify:mobile-browser": "node scripts/verify/mobile-browser-smoke.mjs",
    "verify:pandart-real-codex": "node scripts/verify/pandart-real-codex-browser.mjs",
    "verify:authorization-logout": "node scripts/verify/authorization-logout-boundary.mjs",
    "verify:multi-source-authorization": "node scripts/verify/multi-source-authorization.mjs",
    "verify:productized-onboarding": "node scripts/verify/productized-onboarding.mjs",
    "verify:bridge-full-access-policy": "node scripts/verify/bridge-full-access-policy.mjs",
    "verify:desktop-ai-cli": "node scripts/verify/desktop-ai-cli-control.mjs",
    "verify:relay-e2ee": "node scripts/verify/relay-e2ee.mjs",
    "verify:relay-backpressure": "node scripts/verify/relay-backpressure.mjs",
    "verify:adapter-syllo": "node scripts/verify/adapter-syllo.mjs",
    "verify:relay-local-control": "node examples/relay-local-control/run-local.mjs",
    "verify:relay-local-control:blackbox": "node examples/relay-local-control/blackbox.mjs",
    "verify:selfhost-profile": "node scripts/verify/selfhost-profile.mjs",
    "verify:multi-account-realtime": "node scripts/verify/multi-account-realtime-fanout.mjs",
    "verify:fake-source-matrix": "node scripts/verify/fake-source-matrix.mjs",
    "verify:desktop-lite": "node scripts/verify/desktop-lite-smoke.mjs",
    "verify:spec": "node scripts/verify/spec-traceability.mjs",
    "verify:installed-desktop-e2e": "node scripts/verify/installed-desktop-e2e.mjs",
    "verify:account-e2e": "node scripts/verify/account-password-e2e.mjs",
    "verify:concurrency:matrix": "node scripts/verify/concurrency-matrix.mjs",
    "verify:concurrency:cloud": "node scripts/verify/cloud-concurrency-matrix.mjs",
    "verify:real-codex:queue": "node scripts/verify/real-codex-queue.mjs",
    "verify:bridge-notes": "node scripts/verify/bridge-notes-dogfood.mjs",
    "verify:performance": "node scripts/verify/account-password-e2e.mjs",
    "verify:performance:matrix": "node scripts/verify/performance-matrix.mjs",
    "verify:performance:real-codex": "PANDA_BRIDGE_REAL_CODEX=1 node scripts/verify/account-password-e2e.mjs",
    "verify:performance:matrix:real-codex": "PANDA_BRIDGE_REAL_CODEX=1 node scripts/verify/performance-matrix.mjs",
    "cloud:dev": "npm --workspace @panda-bridge/cloud-worker run dev",
    "cloud:deploy": "npm run build:web && npm --workspace @panda-bridge/cloud-worker run deploy",
    "cloud:migrate": "node scripts/cloud/migrate.mjs",
    "connector": "node apps/connector-cli/src/cli.mjs",
    "desktop:icon:mac": "node scripts/desktop/build-icon.mjs",
    "desktop:install:mac": "node scripts/desktop/install-macos.mjs",
    "desktop:package:mac": "node scripts/desktop/package-macos.mjs",
    "desktop:dev": "npm --workspace @panda-bridge/desktop run run",
    "desktop:build": "npm --workspace @panda-bridge/desktop run build",
    "desktop:check": "npm --workspace @panda-bridge/desktop run check",
    "web:serve": "node scripts/serve-web.mjs",
    "pandart:local": "node scripts/pandart-local-chat.mjs",
    "fake-source:matrix": "node scripts/fake-source-matrix.mjs"
  },
  "dependencies": {
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
